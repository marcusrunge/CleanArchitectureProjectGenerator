<UserControl x:Class="MarcusRunge.CleanArchitectureProjectGenerator.ProjectCreatorToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:MarcusRunge.CleanArchitectureProjectGenerator.Properties"
             xmlns:viewmodels="clr-namespace:MarcusRunge.CleanArchitectureProjectGenerator.ViewModels"
             xmlns:constants="clr-namespace:MarcusRunge.CleanArchitectureProjectGenerator.Constants"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:helpers="clr-namespace:MarcusRunge.CleanArchitectureProjectGenerator.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:ProjectCreatorToolWindowViewModel}"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             helpers:ToolWindowCloser.CloseRequested="{Binding IsOnCloseRequested}">
    <!--<i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand, Mode=OneWay}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding UnloadedCommand, Mode=OneWay}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>-->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Form -->
        <StackPanel Grid.Row="0">
            <TextBlock Margin="0,0,0,4"
                       FontWeight="SemiBold"
                       Text="{x:Static properties:Resources.ProjectName}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Content="{Binding RootNamespace}"
                          ContentStringFormat="{}{0}."
                          Style="{DynamicResource {x:Static vsshell:VsResourceKeys.CheckBoxStyleKey}}"
                          IsChecked="{Binding IsRootNamespaceSelected, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox  Grid.Column="1" Style="{DynamicResource {x:Static vsshell:VsResourceKeys.TextBoxStyleKey}}"
                     MinHeight="26"
                     Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Margin="0,0,0,4"
                       FontWeight="SemiBold"
                       Text="{x:Static properties:Resources.BaseNamespace}" />

            <TextBox Style="{DynamicResource {x:Static vsshell:VsResourceKeys.TextBoxStyleKey}}"
                     MinHeight="26"
                     Text="{Binding BaseNamespace, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Margin="0,0,0,4"
               FontWeight="SemiBold"
               Text="{x:Static properties:Resources.DotNetVersion}" />

            <ComboBox Style="{DynamicResource {x:Static vsshell:VsResourceKeys.ComboBoxStyleKey}}"
                      MinHeight="26"
                      ItemsSource="{Binding DotNetVersions}"
                      SelectedItem="{Binding SelectedDotNetVersion, UpdateSourceTrigger=PropertyChanged}"
                      VerticalContentAlignment="Center" />
        </StackPanel>

        <!-- Command row -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <Border Height="1"
                    Margin="0,0,0,8"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMenuSeparatorKey}}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{DynamicResource {x:Static vsshell:VsResourceKeys.ButtonStyleKey}}"
                        MinWidth="90"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Content="{x:Static properties:Resources.Create}"
                        Command="{Binding ButtonCommand, Mode=OneWay}"
                        CommandParameter="{x:Static constants:ButtonCommandParameters.Create}" />

                <Button Style="{DynamicResource {x:Static vsshell:VsResourceKeys.ButtonStyleKey}}"
                        MinWidth="90"
                        IsCancel="True"
                        Content="{x:Static properties:Resources.Cancel}"
                        Command="{Binding ButtonCommand, Mode=OneWay}"
                        CommandParameter="{x:Static constants:ButtonCommandParameters.Cancel}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>