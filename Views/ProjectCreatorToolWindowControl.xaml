<UserControl x:Class="MarcusRunge.CleanArchitectureProjectGenerator.ProjectCreatorToolWindowControl"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:MarcusRunge.CleanArchitectureProjectGenerator.Properties"
             xmlns:viewmodels="clr-namespace:MarcusRunge.CleanArchitectureProjectGenerator.ViewModels" 
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:constants="clr-namespace:MarcusRunge.CleanArchitectureProjectGenerator.Constants"
             d:DataContext="{d:DesignInstance Type=viewmodels:ProjectCreatorToolWindowViewModel}"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             Name="ProjectCreatorToolWindow">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Label Content="{x:Static properties:Resources.ProjectName}" />
            <TextBox/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static properties:Resources.Create}" Command="{Binding ButtonCommand, Mode=OneWay}" CommandParameter="{x:Static constants:ButtonCommandParameters.Create}"/>
                <Button Content="{x:Static properties:Resources.Cancel}" Command="{Binding ButtonCommand, Mode=OneWay}" CommandParameter="{x:Static constants:ButtonCommandParameters.Cancel}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
